            4.0   0.09
          </tableData>
        </table>
      </function>

      <function name="aero/coefficient/CDi">
        <description>诱导阻力系数</description>
        <product>
          <property>aero/alpha-rad</property>
          <property>aero/alpha-rad</property>
          <value>0.18</value>
        </product>
      </function>

      <function name="aero/coefficient/CDde">
        <description>舵面阻力增量</description>
        <product>
          <property>fcs/elevator-pos-rad</property>
          <property>fcs/elevator-pos-rad</property>
          <value>0.25</value>
        </product>
      </function>
    </axis>

    <axis name="SIDE" type="SIDE">
      <function name="aero/coefficient/CYb">
        <description>侧力系数</description>
        <product>
          <property>aero/beta-rad</property>
          <table>
            <independentVar lookup="row">velocities/mach</independentVar>
            <tableData>
              0.3  -18.0
              0.5  -19.2
              0.8  -20.4
              1.0  -19.2
              1.2  -18.0
              1.5  -15.6
              2.0  -14.4
              3.0  -12.0
              4.0  -10.8
            </tableData>
          </table>
        </product>
      </function>
    </axis>

    <axis name="PITCH" type="PITCH">
      <function name="aero/coefficient/Cmde">
        <description>舵面俯仰力矩系数</description>
        <product>
          <property>fcs/elevator-pos-rad</property>
          <table>
            <independentVar lookup="row">velocities/mach</independentVar>
            <tableData>
              0.2   5.0
              0.4   5.5
              0.6   6.0
              0.8   6.8
              1.0   7.2
              1.2   7.0
              1.5   6.5
              2.0   6.0
              3.0   5.5
              4.0   5.0
            </tableData>
          </table>
        </product>
      </function>

      <function name="aero/coefficient/Cmalpha">
        <description>静稳定力矩系数（放宽静稳定度）</description>
        <product>
          <property>aero/alpha-rad</property>
          <value>0.25</value>
        </product>
      </function>

      <function name="aero/coefficient/Cmq">
        <description>俯仰阻尼力矩系数</description>
        <product>
          <property>velocities/q-aero-rad_sec</property>
          <value>-20.0</value>
        </product>
      </function>
    </axis>

    <axis name="YAW" type="YAW">
      <function name="aero/coefficient/Cndr">
        <description>舵面偏航力矩系数</description>
        <product>
          <property>fcs/rudder-pos-rad</property>
          <value>-6.5</value>
        </product>
      </function>

      <function name="aero/coefficient/Cnr">
        <description>偏航阻尼力矩系数</description>
        <product>
          <property>velocities/r-aero-rad_sec</property>
          <value>-15.0</value>
        </product>
      </function>
    </axis>

    <axis name="ROLL" type="ROLL">
      <function name="aero/coefficient/Clda">
        <description>副翼滚转力矩系数（正舵偏→正Cl→右滚转）</description>
        <product>
          <property>fcs/aileron-pos-rad</property>
          <value>10.0</value>
        </product>
      </function>

      <function name="aero/coefficient/Clp">
        <description>滚转阻尼力矩系数</description>
        <product>
          <property>velocities/p-aero-rad_sec</property>
          <value>-30.0</value>
        </product>
      </function>
    </axis>
  </aerodynamics>

</fdm_config>
